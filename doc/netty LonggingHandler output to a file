
import io.netty.handler.logging.LoggingHandler;
import io.netty.util.ResourceLeakDetector;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.context.annotation.ComponentScan;

import io.netty.util.internal.logging.InternalLoggerFactory;
import io.netty.util.internal.logging.JdkLoggerFactory;
import java.io.File;
import java.io.IOException;
import java.util.logging.*;


@SpringBootApplication
@ComponentScan({"com.illiad.proxy"})
public class ProxyApplication {
	public static void main(String[] args) {

		// 1. Force Netty to use Java Util Logging (JUL)
		InternalLoggerFactory.setDefaultFactory(JdkLoggerFactory.INSTANCE);

		// 2. Create the directory manually
		File logDir = new File("logs");
		if (!logDir.exists()) logDir.mkdirs();

		// 3. Configure the Logger for LoggingHandler
		Logger logger = Logger.getLogger(LoggingHandler.class.getName());
		logger.setUseParentHandlers(false); // Prevents console spam

		// 4. Set up the FileHandler with a Wireshark-friendly format
        FileHandler fh;
        try {
            fh = new FileHandler("logs/netty_capture.log");
        } catch (IOException e) {
            throw new RuntimeException(e);
        }
        fh.setFormatter(new Formatter() {
			@Override
			public String format(LogRecord record) {
				// Wireshark's "Import from Hex Dump" needs just the hex data
				return record.getMessage() + "\n";
			}
		});
		logger.addHandler(fh);
		logger.setLevel(Level.FINEST); // Ensure the logger itself allows DEBUG/FINEST levels

		// direct memory leakage test
		// ResourceLeakDetector.setLevel(ResourceLeakDetector.Level.PARANOID);
		SpringApplication.run(ProxyApplication.class, args);
	}

}


